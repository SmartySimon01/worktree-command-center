{
  "name": "worktree-command-center",
  "version": "0.1.0",
  "description": "Run many Claude Code sessions in parallel, each in its own git worktree, tiled in one view.",
  "license": "MIT",
  "author": "Ronald Fridlyand",
  "main": "dist/main.js",
  "scripts": {
    "postinstall": "node scripts/fix-electron.mjs && node scripts/fix-node-pty.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs",
    "start": "npm run build && electron .",
    "test": "vitest run",
    "dist": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "0.25.5",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.ronaldfridlyand.worktree-command-center",
    "productName": "Worktree Command Center",
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "shortcutName": "Worktree Command Center"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] },
        { "target": "zip", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "extraResources": [
      {
        "from": "pty-sidecar",
        "to": "pty-sidecar"
      },
      {
        "from": "node_modules/node-pty",
        "to": "pty-sidecar/node_modules/node-pty",
        "filter": ["package.json", "lib/**/*", "prebuilds/**/*"]
      }
    ]
  }
}
